# Lambda backend example environment configuration.
# Copy to .env and adjust values for your machine.

ENV=development
DEBUG=true

# PostgreSQL connection URL for SQLAlchemy and Alembic.
# Example local database user and database:
#   CREATE USER lambda_user WITH PASSWORD 'strongpassword123';
#   CREATE DATABASE lambda_db OWNER lambda_user;
DATABASE_URL=postgresql://lambda_user:strongpassword123@localhost:5432/lambda_db

# JWT secret: set a strong random value in real deployments.
SECRET_KEY=change-me-in-production

# Google OAuth credentials (Phase 3).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend origin for CORS.
FRONTEND_URL=http://localhost:5173

